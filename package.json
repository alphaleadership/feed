{
  "name": "hexo-site",
  "version": "0.1.6",
  "private": true,
  "scripts": {
    "build": " npm run clean && node index.js && node indexator.js && node tools/import && npm run import:remote && node detecter-fuites-sans-nombre && node update-breach-links.js && node remove-invalid-breaches.js && node clean-html-tags",
    "clean": "node manager && node update_breach_attribution&& node tools/resort-breaches && npm run update-slugs && hexo clean",
    "deploy": "hexo deploy --config build.yml",
    "server": "hexo server",
    "import": "node tools/import.js",
    "import:remote": "node import-remote-breaches.js",
    "update-slugs": "node find-acronyms.js && node update-slugs-to-delete.js",
    "add:breach": "node scripts/add-breach.js",
    "classify": "node tools/classify-breaches.js"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.1",
    "enquirer": "^2.4.1",
    "fuse.js": "^7.3.0",
    "hexo": "^8.1.1",
    "hexo-abbrlink3": "^1.0.2",
    "hexo-deployer-git": "^4.0.0",
    "hexo-enhancer": "^1.0.10",
    "hexo-everyday-calendar": "^1.3.12",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-feed": "github:thomas-iniguez-visioli/hexo-generator-feed",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-search": "^2.4.3",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.0",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "hexo-theme-landscape": "^1.0.0",
    "inquirer": "^13.4.1",
    "js-yaml": "^4.1.1",
    "jsonstream": "^1.0.3",
    "lowdb": "^7.0.1",
    "resend": "^6.10.0",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.2",
    "sudoku": "^0.0.3"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3"
  }
}
