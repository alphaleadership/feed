<style>
  :root {
    --bg-main: #0f172a;
    --bg-card: #1e293b;
    --border-color: #334155;
    --text-primary: #f8fafc;
    --text-secondary: #cbd5e1;
    --accent: #38bdf8;
    --accent-hover: #7dd3fc;
  }

  #threat-actors-container {
    padding: 2em 0;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: var(--text-primary);
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .header {
    margin-bottom: 2em;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1em;
  }

  .actor-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5em;
    margin-bottom: 1.5em;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .actor-name {
    font-size: 1.5em;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.5em;
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  .actor-name i {
    font-size: 0.8em;
  }

  .breach-list {
    list-style: none;
    padding: 0;
    margin: 1em 0 0 0;
  }

  .breach-item {
    padding: 0.5em 0;
    border-bottom: 1px solid rgba(51, 65, 85, 0.5);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .breach-item:last-child {
    border-bottom: none;
  }

  .breach-link {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breach-link:hover {
    color: var(--accent);
  }

  .breach-date {
    color: var(--text-secondary);
    font-size: 0.85em;
  }

  .stats {
    font-size: 0.9em;
    color: var(--text-secondary);
    margin-bottom: 1em;
  }

  .search-container {
    margin-bottom: 2em;
  }

  .search-input {
    width: 100%;
    padding: 0.8em 1.2em;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 1em;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
  }
</style>

<div id="threat-actors-container">
  <div class="header">
    <h1>Pirates et Groupes de Hackers</h1>
    <p style="color: var(--text-secondary)">Exploration des fuites de données par auteur de l'attaque.</p>
  </div>

  <div class="search-container">
    <input type="text" id="actor-search" class="search-input" placeholder="Rechercher un pirate ou un groupe...">
  </div>

  <div id="actors-list">
    <p>Chargement des données...</p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const listContainer = document.getElementById('actors-list');
    const searchInput = document.getElementById('actor-search');
    let actorsData = [];

    fetch('/data/breaches.json')
      .then(response => response.json())
      .then(data => {
        const breaches = data.breaches;
        const actorsMap = {};

        breaches.forEach(breach => {
          if (breach.Attribution && breach.Attribution !== 'null' && breach.Attribution !== 'Unknown') {
            const actor = breach.Attribution;
            if (!actorsMap[actor]) {
              actorsMap[actor] = {
                name: actor,
                breaches: []
              };
            }
            actorsMap[actor].breaches.push(breach);
          }
        });

        actorsData = Object.values(actorsMap).sort((a, b) => b.breaches.length - a.breaches.length);
        renderActors(actorsData);
      })
      .catch(error => {
        listContainer.innerHTML = `<p style="color: #ef4444;">Erreur lors du chargement des données: ${error.message}</p>`;
      });

    searchInput.addEventListener('input', (e) => {
      const searchTerm = e.target.value.toLowerCase();
      const filtered = actorsData.filter(actor => 
        actor.name.toLowerCase().includes(searchTerm) || 
        actor.breaches.some(b => (b.Title || b.Name).toLowerCase().includes(searchTerm))
      );
      renderActors(filtered);
    });

    function renderActors(actors) {
      if (actors.length === 0) {
        listContainer.innerHTML = '<p>Aucun pirate trouvé.</p>';
        return;
      }

      function neutralize(text) {
        if (!text) return '';
        // Neutralize URLs (remove protocol, replace dots)
        let neutral = text.replace(/https?:\/\//gi, '');
        // Neutralize Email (replace @ and dots)
        neutral = neutral.replace(/@/g, ' [at] ').replace(/\./g, '[.]');
        return neutral;
      }

      let html = '';
      actors.forEach(actor => {
        const neutralizedName = neutralize(actor.name);
        html += `
          <div class="actor-card">
            <div class="actor-name">
              <i class="fa fa-user-secret"></i> ${neutralizedName}
            </div>
            <div class="stats">${actor.breaches.length} fuite(s) revendiquée(s)</div>
            <div class="breach-list">
              ${actor.breaches.sort((a, b) => new Date(b.BreachDate) - new Date(a.BreachDate)).map(breach => `
                <div class="breach-item">
                  <a href="/fuites?id=${breach.index}" class="breach-link">${breach.Title || breach.Name}</a>
                  <span class="breach-date">${new Date(breach.BreachDate).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      });
      listContainer.innerHTML = html;
    }
  });
</script>
