<div class="row page">
<script src="<%- config.url %>/js/index.js"></script>

	<% if (theme.widgets.length) { %>
	<div class="col-md-9">
	<% } else { %>
	<div class="col-md-12">
	<% } %>

	<!-- Liens rapides -->
	

	<!-- Paragraphe explicatif -->
	<div class="intro-section card shadow-sm mb-4" style="background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%); border: 1px solid rgba(56, 189, 248, 0.3);">
		<div class="card-body" style="padding: 2rem;">
			<h2 style="color: #38bdf8; margin-bottom: 1rem; font-size: 1.8rem;">
				<i class="fa fa-shield me-2"></i>Bienvenue sur le répertoire des fuites de données
			</h2>
			<p style="color: #cbd5e1; font-size: 1.1rem; line-height: 1.8; margin-bottom: 1rem;">
				Ce site recense et documente les <strong style="color: #fbbf24;">fuites de données</strong> affectant des millions d'utilisateurs à travers le monde. 
				Notre mission est de sensibiliser le public aux risques liés à la cybersécurité et de fournir des informations détaillées sur chaque incident.
			</p>
			<p style="color: #cbd5e1; font-size: 1.1rem; line-height: 1.8; margin-bottom: 1rem;">
				Vous trouverez ici des <strong style="color: #4ade80;">statistiques détaillées</strong>, les types de données compromises, 
				les entreprises touchées, et des conseils pour vérifier si vos informations ont été exposées. 
				Chaque fuite est documentée avec sa date, le nombre de comptes affectés, et les données exposées.
			</p>
			<div style="background: rgba(56, 189, 248, 0.1); border-left: 4px solid #38bdf8; padding: 1rem; border-radius: 4px; margin-top: 1.5rem;">
				<p style="color: #e2e8f0; margin: 0; font-size: 1rem;">
					<i class="fa fa-info-circle me-2" style="color: #38bdf8;"></i>
					<strong>Conseil :</strong> Utilisez les archives pour explorer les fuites par année, ou consultez les statistiques ci-dessous pour découvrir les tendances et les secteurs les plus touchés.
				</p>
			</div>
		</div>
	</div>

	<!-- Fuites critiques récentes -->
	<div class="critical-breaches card shadow-sm mb-4" style="background: linear-gradient(135deg, #450a0a 0%, #7f1d1d 100%); border: 2px solid #dc2626;">
		<div class="card-header text-white d-flex align-items-center border-0" style="background: rgba(0,0,0,0.5) !important; border-bottom: 2px solid rgba(220, 38, 38, 0.5) !important;">
			<i class="fa fa-exclamation-triangle me-3 fs-4" style="color: #fca5a5;"></i>
			<h3 class="mb-0 text-uppercase letter-spacing-1">
				⚠️ Fuites Critiques Récentes
			</h3>
		</div>
		<div class="card-body" style="background: #3f0e0e; padding: 1.5rem;">
			<div id="critical-breaches-container">
				<div class="text-center py-5">
					<div class="spinner-border text-danger" role="status">
						<span class="visually-hidden">Chargement...</span>
					</div>
				</div>
			</div>
		</div>
	</div>
	

	<!-- Statistiques globales -->
	<div class="global-stats card shadow-sm mb-4" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border: none;">
		<div class="card-header bg-dark text-white" style="background: rgba(0,0,0,0.5) !important; border-bottom: 2px solid rgba(255,255,255,0.1);">
			<h3 class="mb-0">📈 Statistiques globales</h3>
		</div>
		<div class="card-body" style="background: #1e1e2e; padding: 1.5rem;">
			<div class="row" id="global-stats-container">
				<div class="col-12 text-center py-5">
					<div class="spinner-border text-primary" role="status">
						<span class="visually-hidden">Chargement...</span>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Données les plus fuitées -->
	<div class="dataclass-stats card shadow-sm mb-4" style="background: linear-gradient(135deg, #2e1a1a 0%, #3e1616 100%); border: none;">
		<div class="card-header bg-dark text-white" style="background: rgba(0,0,0,0.5) !important; border-bottom: 2px solid rgba(255,255,255,0.1);">
			<h3 class="mb-0">🔐 Types de données les plus fuités </h3>
		</div>
		<div class="card-body" style="background: #2e1e1e; padding: 1.5rem;">
			<div class="row" id="dataclass-container">
				<div class="col-12 text-center py-5">
					<div class="spinner-border text-danger" role="status">
						<span class="visually-hidden">Chargement...</span>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Entreprises les plus touchées -->
	<div class="company-stats card shadow-sm mb-4" style="background: linear-gradient(135deg, #1f2937 0%, #111827 100%); border: none;">
		<div class="card-header bg-dark text-white" style="background: rgba(0,0,0,0.5) !important; border-bottom: 2px solid rgba(255,255,255,0.1);">
			<h3 class="mb-0">🏢 Entreprises / Sites les plus touchés </h3>
		</div>
		<div class="card-body" style="background: #1f2937; padding: 1.5rem;">
			<div class="row" id="company-container">
				<div class="col-12 text-center py-5">
					<div class="spinner-border text-success" role="status">
						<span class="visually-hidden">Chargement...</span>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Catégories les plus fréquentes -->
	<div class="category-stats card shadow-sm mb-4">
		<div class="card-header bg-dark text-white">
			<h3 class="mb-0">📊 Catégories les plus fréquentes </h3>
			<small class="text-muted" id="breach-count">Chargement...</small>
		</div>
		<div class="card-body">
			<div class="row" id="category-container">
				<div class="col-12 text-center py-5">
					<div class="spinner-border text-primary" role="status">
						<span class="visually-hidden">Chargement...</span>
					</div>
				</div>
			</div>
		</div>
	</div>

	<script>
		const invalidcategory=["hygiène numérique","sécurité","cybersécurité","cybercriminalité","cyberguerre"]
		// Charger et analyser les données avec fetch
		fetch('<%- config.url %>/data/breaches.json')
			.then(response => response.json())
			.then(data => {
				const categoryBreaches = {};
				const dataClassStats = {};
				const companyStats = {};
				const yearStats = {};
				
				// Calculer les statistiques globales
				let totalPwnCount = 0;
				let verifiedCount = 0;
				let sensitiveCount = 0;
				const currentYear = new Date().getFullYear();
				const lastYear = currentYear - 1;
				let currentYearCount = 0;
				let lastYearCount = 0;
				
				// Associer chaque catégorie avec ses fuites
				data.breaches.filter((item)=>{return ! item.isRetired}).forEach(breach => {
					totalPwnCount += (breach.PwnCount || 0);
					if (breach.IsVerified) verifiedCount++;
					if (breach.IsSensitive) sensitiveCount++;
					
					const breachYear = new Date(breach.BreachDate).getFullYear();
					if (breachYear === currentYear) currentYearCount++;
					if (breachYear === lastYear) lastYearCount++;
					
					if (!yearStats[breachYear]) {
						yearStats[breachYear] = { count: 0, pwnCount: 0 };
					}
					yearStats[breachYear].count++;
					yearStats[breachYear].pwnCount += (breach.PwnCount || 0);
					
					if (breach.DataClasses && Array.isArray(breach.DataClasses)) {
						breach.DataClasses.forEach(dc => {
							if (!dataClassStats[dc]) {
								dataClassStats[dc] = { count: 0, pwnCount: 0 };
							}
							dataClassStats[dc].count++;
							dataClassStats[dc].pwnCount += (breach.PwnCount || 0);
						});
					}

					// Stats pour les entreprises / sites
					let compName = breach.Domain || breach.Title || breach.Name;
					let compDomain = breach.Domain;
					
					if (compName) {
						let normName = compName.toLowerCase();
						
						// Normaliser France Travail
						if (normName.includes('france travail') || normName.includes('pole emploi') || normName.includes('pôle emploi') || normName.includes('francetravail')) {
							compName = 'France Travail';
							compDomain = 'francetravail.fr';
						} else if (compName.toLowerCase().includes(' fuite du ')) {
							compName = compName.replace(/ fuite du .*/i, '').trim();
							// Capitaliser la première lettre si tout est en minuscules
							if (compName === compName.toLowerCase()) {
								compName = compName.charAt(0).toUpperCase() + compName.slice(1);
							}
						}

						// Uniformiser la casse
						const keyName = compName.toLowerCase();

						if (!companyStats[keyName]) {
							companyStats[keyName] = { 
								name: compName, 
								count: 0, 
								pwnCount: 0,
								domain: compDomain
							};
						}
						companyStats[keyName].count++;
						companyStats[keyName].pwnCount += (breach.PwnCount || 0);
						if (compDomain && !companyStats[keyName].domain) {
							companyStats[keyName].domain = compDomain;
						}
					}

					if (breach.categories && Array.isArray(breach.categories)) {
						breach.categories.map(item=>{
							return item.split("fuite")[0]
						}).forEach(category => {
							if(category==""){
								return
							}
								if(!isNaN(parseInt(category))){
								invalidcategory.push(category)
							}
							if(invalidcategory.includes(category.toLowerCase())){
								return
							}
						
							if (!categoryBreaches[category.toLowerCase()]) {
								categoryBreaches[category.toLowerCase()] = [];
							}
							categoryBreaches[category.toLowerCase()].push({
								name: breach.Name,
								title: breach.Title,
								slug: breach.slug,
								path: breach.index,
								pwnCount: breach.PwnCount,
								date: breach.BreachDate,
								nsfw:breach.isNSFW,
								severityLevel: breach.SeverityLevel
							
						
							
							
							
						
							});
						});
					}
				});
				
				// Afficher les 5 fuites critiques les plus récentes
				const criticalBreaches = data.breaches
					.filter(breach => breach.IsCritical && !breach.IsRetired)
					.sort((a, b) => new Date(b.BreachDate) - new Date(a.BreachDate))
					.slice(0, 5);
				
				const criticalContainer = document.getElementById('critical-breaches-container');
				if (criticalContainer && criticalBreaches.length > 0) {
					criticalContainer.innerHTML = `
						<div class="row">
							${criticalBreaches.map((breach, idx) => {
								const date = new Date(breach.BreachDate);
								const formattedDate = date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
								const pwnDisplay = breach.PwnCount >= 1000000 ? (breach.PwnCount / 1000000).toFixed(1) + 'M' : breach.PwnCount.toLocaleString();
								const dataClassesDisplay = breach.DataClasses && breach.DataClasses.length > 0 
									? breach.DataClasses.slice(0, 3).join(', ') + (breach.DataClasses.length > 3 ? '...' : '')
									: 'Données non spécifiées';
								
								return `
									<div class="col-md-6 col-lg-4 mb-3">
										<div class="card h-100" style="background: linear-gradient(145deg, #7f1d1d 0%, #5f0f0f 100%); border: 2px solid #dc2626;">
											<div class="card-body">
												<div class="d-flex justify-content-between align-items-start mb-2">
													<span class="badge bg-danger fs-6">#${idx + 1}</span>
													<span class="badge bg-dark" style="font-size: 0.7em;">
														<i class="fa fa-calendar me-1"></i>${formattedDate}
													</span>
												</div>
												<h5 class="card-title mb-2" style="color: #fca5a5;">
													<i class="fa fa-exclamation-triangle me-2"></i>${breach.Title || breach.Name}
												</h5>
												<p class="mb-2" style="color: #fecaca; font-size: 0.9rem;">
													<i class="fa fa-users me-2"></i><strong>${pwnDisplay}</strong> comptes compromis
												</p>
												<p class="mb-2" style="color: #fecaca; font-size: 0.85rem;">
													<i class="fa fa-database me-2"></i>
													${dataClassesDisplay}
												</p>
												<a href="<%- config.url %>/fuites?id=${breach.index}" class="btn btn-sm btn-danger mt-2 w-100">
													<i class="fa fa-eye me-1"></i>Voir les détails
												</a>
											</div>
										</div>
									</div>
								`;
							}).join('')}
						</div>
					`;
				} else if (criticalContainer) {
					criticalContainer.innerHTML = '<p class="text-muted text-center py-4">Aucune fuite critique détectée.</p>';
				}
				
				// Afficher les statistiques globales
				const globalStatsContainer = document.getElementById('global-stats-container');
				if (globalStatsContainer) {
					const avgPerYear = (data.totalBreaches / Object.keys(yearStats).length).toFixed(1);
					const verifiedPercent = ((verifiedCount / data.totalBreaches) * 100).toFixed(1);
					const yearComparison = currentYearCount > lastYearCount ? 
						`<span class="text-danger">↑ ${((currentYearCount - lastYearCount) / lastYearCount * 100).toFixed(1)}%</span>` :
						`<span class="text-success">↓ ${((lastYearCount - currentYearCount) / lastYearCount * 100).toFixed(1)}%</span>`;
					
					globalStatsContainer.innerHTML = `
						<div class="col-md-3 col-sm-6 mb-3">
							<div class="stat-card p-3 text-center h-100" style="background: linear-gradient(145deg, #2a2a3e 0%, #1f1f2e 100%); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
								<div class="stat-icon mb-2" style="font-size: 2rem;">💾</div>
								<h4 style="color: #6c9fff; margin-bottom: 0.5rem;">${(totalPwnCount / 1000000000).toFixed(2)}Md</h4>
								<p class="text-muted mb-0" style="font-size: 0.9rem;">Comptes compromis</p>
							</div>
						</div>
						<div class="col-md-3 col-sm-6 mb-3">
							<div class="stat-card p-3 text-center h-100" style="background: linear-gradient(145deg, #2a2a3e 0%, #1f1f2e 100%); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
								<div class="stat-icon mb-2" style="font-size: 2rem;">📅</div>
								<h4 style="color: #ffa500; margin-bottom: 0.5rem;">${avgPerYear}</h4>
								<p class="text-muted mb-0" style="font-size: 0.9rem;">Fuites par an (moyenne)</p>
							</div>
						</div>
						<div class="col-md-3 col-sm-6 mb-3">
							<div class="stat-card p-3 text-center h-100" style="background: linear-gradient(145deg, #2a2a3e 0%, #1f1f2e 100%); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
								<div class="stat-icon mb-2" style="font-size: 2rem;">✅</div>
								<h4 style="color: #4ade80; margin-bottom: 0.5rem;">${verifiedPercent}%</h4>
								<p class="text-muted mb-0" style="font-size: 0.9rem;">Fuites vérifiées</p>
							</div>
						</div>
						<div class="col-md-3 col-sm-6 mb-3">
							<div class="stat-card p-3 text-center h-100" style="background: linear-gradient(145deg, #2a2a3e 0%, #1f1f2e 100%); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
								<div class="stat-icon mb-2" style="font-size: 2rem;">📊</div>
								<h4 style="color: #ff6b6b; margin-bottom: 0.5rem;">${currentYearCount} ${yearComparison}</h4>
								<p class="text-muted mb-0" style="font-size: 0.9rem;">${currentYear} vs ${lastYear}</p>
							</div>
						</div>
					`;
				}
				
				console.log(categoryBreaches)
				// Trier et prendre les 15 premiers
				const sortedCategories = Object.entries(categoryBreaches)
					.sort((a, b) => b[1].length - a[1].length)
					.slice(0, 15)
					.map(([name, breaches]) => ({ 
						name:name||"inconnu", 
						count: breaches.length,
						breaches: breaches.sort((a, b) => b.count - a.count).slice(0, 50),
						percentage: ((breaches.length / data.totalBreaches) * 100).toFixed(1) 
					}));
				
				// Trier et préparer les stats DataClasses
				const sortedDataClasses = Object.entries(dataClassStats)
					.sort((a, b) => b[1].count - a[1].count)
					.slice(0, 8)
					.map(([name, stats]) => ({
						name,
						count: stats.count,
						pwnCount: stats.pwnCount
					}));

				const dcContainer = document.getElementById('dataclass-container');
				if (dcContainer) {
					dcContainer.innerHTML = sortedDataClasses.map((dc, idx) => {
						const borderClass = idx < 3 ? 'border-danger' : idx < 7 ? 'border-warning' : 'border-info';
						const badgeClass = idx < 3 ? 'bg-danger' : idx < 7 ? 'bg-warning text-dark' : 'bg-info';
						const percentage = ((dc.count / data.totalBreaches) * 100).toFixed(1);
						return `
							<div class="col-md-3 col-sm-6 mb-3">
								<div class="note-card p-3 border rounded ${borderClass} h-100" style="background: linear-gradient(145deg, #382525 0%, #3e2a2a 100%);">
									<div class="d-flex justify-content-between align-items-center mb-2">
										<span class="badge ${badgeClass} fs-6">#${idx + 1}</span>
										<span class="text-muted small">${percentage}%</span>
									</div>
									<h5 class="mb-2" style="color:#e0e0e0; font-size: 1.1rem; word-break: break-word;">${dc.name}</h5>
									<p class="mb-1 text-muted" style="font-size:0.9em;"><strong>${dc.count.toLocaleString()}</strong> fuites</p>
									<p class="mb-0 text-muted" style="font-size:0.8em; opacity: 0.8;">
										<i class="fa fa-users" style="margin-right: 4px;"></i>
										~<strong>${dc.pwnCount >= 1000000000 ? (dc.pwnCount / 1000000000).toFixed(2) + 'Md' : (dc.pwnCount / 1000000).toFixed(1) + 'M'}</strong> comptes
									</p>
								</div>
							</div>
						`;
					}).join('');
				}

				// Trier et préparer les stats Entreprises
				const sortedCompanies = Object.values(companyStats)
					.sort((a, b) => b.pwnCount - a.pwnCount)
					.slice(0, 12);

				const compContainer = document.getElementById('company-container');
				if (compContainer) {
					compContainer.innerHTML = sortedCompanies.map((comp, idx) => {
						const borderClass = idx < 3 ? 'border-danger' : idx < 7 ? 'border-warning' : 'border-success';
						const badgeClass = idx < 3 ? 'bg-danger' : idx < 7 ? 'bg-warning text-dark' : 'bg-success';
						const domainLink = comp.domain && comp.domain !== comp.name ? `<br><a href="http://${comp.domain}" target="_blank" rel="noopener noreferrer" style="color:#a7f3d0; font-size: 0.8em; text-decoration: none;"><i class="fa fa-external-link" style="margin-right: 4px;"></i>${comp.domain}</a>` : '';
						const avgPerBreach = comp.count > 0 ? (comp.pwnCount / comp.count) : 0;
						return `
							<div class="col-md-3 col-sm-6 mb-3">
								<div class="note-card p-3 border rounded ${borderClass} h-100" style="background: linear-gradient(145deg, #374151 0%, #1f2937 100%);">
									<div class="d-flex justify-content-between align-items-center mb-2">
										<span class="badge ${badgeClass} fs-6">#${idx + 1}</span>
									</div>
									<h5 class="mb-1" style="color:#f3f4f6; font-size: 1.1rem; word-break: break-word;">${comp.name}${domainLink}</h5>
									<p class="mt-2 mb-1 text-muted" style="font-size:0.9em; color: #9ca3af !important;">
										<i class="fa fa-database" style="margin-right: 4px;"></i>
										<strong>${(comp.pwnCount >= 1000000 ? (comp.pwnCount / 1000000).toFixed(1) + 'M' : comp.pwnCount.toLocaleString())}</strong> comptes
									</p>
									<p class="mb-0 text-muted" style="font-size:0.8em; opacity: 0.8;">
										<i class="fa fa-warning" style="margin-right: 4px;"></i>
										${comp.count} fuite${comp.count > 1 ? 's' : ''} 
										<span style="opacity: 0.7;">(~${avgPerBreach >= 1000000 ? (avgPerBreach / 1000000).toFixed(1) + 'M' : avgPerBreach.toLocaleString(undefined, {maximumFractionDigits: 0})} par fuite)</span>
									</p>
								</div>
							</div>
						`;
					}).join('');
				}

				// Mettre à jour le compteur
				document.getElementById('breach-count').textContent = 
					`Basé sur ${data.totalBreaches.toLocaleString()} fuites analysées`;
				
				// Générer le HTML des catégories
				const container = document.getElementById('category-container');
				container.innerHTML = sortedCategories.map((cat, idx) => {
					const borderClass = idx < 3 ? 'border-danger' : idx < 8 ? 'border-warning' : 'border-info';
					const badgeClass = idx < 3 ? 'bg-danger' : idx < 8 ? 'bg-warning text-dark' : 'bg-info';
					
					const totalPwnInCategory = cat.breaches.reduce((sum, b) => sum + (b.pwnCount || 0), 0);
					const avgPwnPerBreach = cat.count > 0 ? (totalPwnInCategory / cat.count) : 0;
					
					const breachLinks = cat.breaches.slice(0, 10).map(breach => {
						const severityColors = {
							'CRITIQUE': 'danger',
							'ÉLEVÉ': 'warning',
							'MODÉRÉ': 'info',
							'FAIBLE': 'secondary'
						};
						const severityBadge = breach.severityLevel ? 
							`<span class="badge bg-${severityColors[breach.severityLevel]} ms-1" style="font-size: 0.65em;">${breach.severityLevel}</span>` : '';
						
						return `<li class="breach-link-item ${breach.nsfw ? 'border-warning' : 'border-info'}">
							<a href="<%- config.url %>/fuites?id=${breach.path}" class="text-decoration-none d-flex justify-content-between align-items-start">
								<span class="flex-grow-1 me-2">
									${breach.title}
									${severityBadge}
								</span>
								<span class="text-muted small" style="white-space: nowrap;">
									${breach.pwnCount ? (breach.pwnCount >= 1000000 ? (breach.pwnCount / 1000000).toFixed(1) + 'M' : breach.pwnCount.toLocaleString()) : 'N/A'}
								</span>
							</a>
						</li>`;
					}).join('');
					
					return `
						<div class="col-md-4 col-sm-6 mb-3">
							<div class="note-card p-3 border rounded ${borderClass} h-100">
								<div class="d-flex justify-content-between align-items-center mb-2">
									<span class="badge ${badgeClass} fs-6">#${idx + 1}</span>
									<span class="text-muted small">${cat.percentage}%</span>
								</div>
								<h5 class="mb-2">${cat.name}</h5>
								<div class="mb-2">
									<p class="mb-1 text-muted">
										<i class="fa fa-warning" style="margin-right: 4px;"></i>
										<strong>${cat.count.toLocaleString()}</strong> fuites
									</p>
									<p class="mb-0 text-muted" style="font-size: 0.85em; opacity: 0.8;">
										<i class="fa fa-users" style="margin-right: 4px;"></i>
										~${totalPwnInCategory >= 1000000000 ? (totalPwnInCategory / 1000000000).toFixed(2) + 'Md' : (totalPwnInCategory / 1000000).toFixed(1) + 'M'} comptes
										<span style="opacity: 0.7;">(~${avgPwnPerBreach >= 1000000 ? (avgPwnPerBreach / 1000000).toFixed(1) + 'M' : avgPwnPerBreach.toLocaleString(undefined, {maximumFractionDigits: 0})} par fuite)</span>
									</p>
								</div>
								<details class="breach-details">
									<summary class="text-primary" style="cursor: pointer;">
										<i class="fa fa-list" style="margin-right: 4px;"></i>
										Top ${Math.min(10, cat.breaches.length)} fuites
									</summary>
									<ul class="breach-list mt-2 ps-3">
										${breachLinks}
									</ul>
								</details>
							</div>
						</div>
					`;
				}).join('');
			})
			.catch(error => {
				console.error('Erreur chargement des données:', error);
				document.getElementById('category-container').innerHTML = 
					'<div class="col-12 text-center text-danger">Erreur de chargement des données</div>';
			});
	</script>

