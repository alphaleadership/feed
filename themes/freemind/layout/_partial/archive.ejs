
<%
  var title = '';
  if (page.archive) {
    if (page.year) title = page.year + (page.month ? '/' + page.month : '');
    else title = __('archive_a');
  }

  // Initialisation des variables temporelles globales
  var ARCHIVE_NOW = new Date();
  var ARCHIVE_NOW_TIME = ARCHIVE_NOW.getTime();
  var ARCHIVE_NEW_PERIOD_DAYS = 7; // Changé de 3 à 7 pour correspondre à "CETTE SEMAINE"
  var ARCHIVE_NEW_PERIOD_MS = ARCHIVE_NEW_PERIOD_DAYS * 24 * 60 * 60 * 1000;

  // Helpers pour le formatage
  var formatNumber = function(n) {
    return new Intl.NumberFormat('fr-FR').format(n);
  };
  var pluralize = function(count, singular, plural) {
    return Math.abs(count) > 1 ? plural : singular;
  };

  // Utiliser les données de breaches.json
  var posts = (site.data && site.data.breaches) ? site.data.breaches.breaches : [];
  var archiveData = {
      years: {},
      months: ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']
  };
  
  // Filtrage et tri initial (une seule fois)
  var filteredPosts = posts.filter(function(item){
    if (!item || !item.Name || item.IsRetired) return false;
    var nameLower = item.Name.toLowerCase();
    return !nameLower.includes('cve-') && !nameLower.includes('cve');
  }).sort(function(a, b) {
    return new Date(b.BreachDate) - new Date(a.BreachDate);
  });

  // Statistiques globales
  var globalTotalPwnRaw = 0;
  filteredPosts.forEach(function(it) {
    globalTotalPwnRaw += (Number(it.PwnCount) || 0);
  });
  var globalTotalBreaches = filteredPosts.length;

  // Groupement par année/mois
  filteredPosts.forEach(function(item) {
      var date = new Date(item.BreachDate);
      var year = date.getFullYear();
      var month = date.getMonth();
      if (!archiveData.years[year]) archiveData.years[year] = {};
      if (!archiveData.years[year][month]) archiveData.years[year][month] = [];
      archiveData.years[year][month].push(item);
  });

   // Calculer les fuites ajoutées récemment
   var addedRecentlyCount = filteredPosts.filter(function(item) {
     var addedDate = new Date(item.AddedDate || item.BreachDate);
     return (addedDate.getTime() + ARCHIVE_NEW_PERIOD_MS) > ARCHIVE_NOW_TIME;
   }).length;

   // Calculer les statistiques de dépassement
   var yearSurpassInfo = {};
   Object.keys(archiveData.years).sort(function(a, b){ return a - b; }).forEach(function(year) {
      var monthsInYear = archiveData.years[year];
      var yearCount = 0;
      Object.keys(monthsInYear).forEach(function(m){ yearCount += monthsInYear[m].length; });
      
      var prevYear = parseInt(year) - 1;
      
      // Calculer le nombre de fuites découvertes en retard (après la fin de l'année de la brèche)
      var lateDiscoveryCount = 0;
      Object.keys(monthsInYear).forEach(function(m) {
        monthsInYear[m].forEach(function(it) {
          var breachDate = new Date(it.BreachDate);
          var addedDate = new Date(it.AddedDate || it.BreachDate);
          var endOfYear = new Date(breachDate.getFullYear(), 11, 31, 23, 59, 59);
          if (addedDate > endOfYear) {
            lateDiscoveryCount++;
          }
        });
      });

      if (archiveData.years[prevYear]) {
        var prevYearCount = 0;
        Object.keys(archiveData.years[prevYear]).forEach(function(m){ prevYearCount += archiveData.years[prevYear][m].length; });
        
        yearSurpassInfo[year] = {
          diff: yearCount - prevYearCount,
          percentage: (prevYearCount > 0 ? (((yearCount - prevYearCount) / prevYearCount * 100).toFixed(1)) : "0"),
          prevYearCount: prevYearCount,
          prevYear: prevYear,
          latePercentage: (yearCount > 0 ? ((lateDiscoveryCount / yearCount) * 100).toFixed(1) : "0")
        };
        yearSurpassInfo[year].percentage = (yearSurpassInfo[year].diff >= 0 ? "+" : "") + yearSurpassInfo[year].percentage + "%";
        
        if (yearCount >= prevYearCount && prevYearCount > 0) {
           var allYearItems = [];
           Object.keys(monthsInYear).forEach(function(monthKey) {
             allYearItems = allYearItems.concat(monthsInYear[monthKey]);
           });
           allYearItems.sort(function(a, b){ return new Date(a.BreachDate) - new Date(b.BreachDate); });
           var surpassDate = new Date(allYearItems[prevYearCount - 1].BreachDate);
           yearSurpassInfo[year].date = surpassDate;
           yearSurpassInfo[year].days = Math.ceil((surpassDate - new Date(year, 0, 1)) / (1000 * 60 * 60 * 24));
        }
      }
   });
%>

<!-- title -->
<div class="page-header <% if (theme.inverse){ %>page-header-inverse<% } %>">
  <h1 class="archive-title title <% if (theme.inverse){ %>title-inverse<% } %>">
    <%= title %>
    <% if (addedRecentlyCount > 0) { %>
      <span class="badge badge-success" style="font-size: 0.4em; vertical-align: middle; background-color: #28a745; margin-left: 10px; padding: 5px 10px;">
        <%= addedRecentlyCount %> NOUVELLE<%= addedRecentlyCount > 1 ? 'S' : '' %> CETTE SEMAINE
      </span>
    <% } %>
  </h1>
</div>

<% if (!filteredPosts || filteredPosts.length === 0) { %>
  <div class="alert alert-info" role="alert">
    Aucune fuite de données trouvée.
  </div>
<% } else { %>
  <div class="row page">
    <div class="<% if (theme.widgets.length) { %>col-md-9<% } else { %>col-md-12<% } %>">
      
      <!-- Résumé global -->
      <div class="archive-summary" style="margin-bottom: 30px; padding: 20px; background: rgba(0,0,0,0.05); border-radius: 8px; border-left: 4px solid #38bdf8;">
        <p style="margin: 0; font-size: 1.2em;">
          <strong>Total :</strong> <%= formatNumber(globalTotalBreaches) %> <%= pluralize(globalTotalBreaches, 'fuite répertoriée', 'fuites répertoriées') %> 
          pour un cumul de <strong><%= formatNumber(globalTotalPwnRaw) %></strong> <%= pluralize(globalTotalPwnRaw, 'ligne', 'lignes') %>.
        </p>
      </div>

      <!-- Navigation par année (en haut) -->
      <div class="archive-year-nav" style="margin-bottom: 40px; border-bottom: 1px solid #444; padding-bottom: 20px;">
        <% Object.keys(archiveData.years).sort(function(a, b){ return a - b; }).forEach(function(year) { 
            var monthsInYear = archiveData.years[year];
            var yearCount = 0;
            var totalPwnRaw = 0;
            var allYearItems = [];
            Object.keys(monthsInYear).forEach(function(m){
              yearCount += monthsInYear[m].length;
              allYearItems = allYearItems.concat(monthsInYear[m]);
              monthsInYear[m].forEach(function(it){ totalPwnRaw += (Number(it.PwnCount) || 0); });
            });
            var totalPwnCountFormatted = formatNumber(totalPwnRaw);
            
            allYearItems.sort(function(a, b){ return new Date(a.BreachDate) - new Date(b.BreachDate); });
            var avgTimeStr = "";
            if (allYearItems.length > 1) {
              var totalDiff = 0;
              for (var i = 1; i < allYearItems.length; i++) {
                totalDiff += new Date(allYearItems[i].BreachDate).getTime() - new Date(allYearItems[i-1].BreachDate).getTime();
              }
              var avgDiffDays = Math.round(totalDiff / (allYearItems.length - 1) / (1000 * 60 * 60 * 24));
              avgTimeStr = " - ⏳ moy. " + avgDiffDays + " j.";
            }

            var lateStr = "";
            if (yearSurpassInfo[year] && yearSurpassInfo[year].latePercentage > 0) {
              lateStr = " - 🔍 " + yearSurpassInfo[year].latePercentage + "% tardives";
            }

            var predictionStr = "";
            var currentYear = ARCHIVE_NOW.getFullYear();
            if (parseInt(year) === currentYear) {
              var startOfYear = new Date(currentYear, 0, 1);
              var daysPassed = Math.ceil((ARCHIVE_NOW_TIME - startOfYear.getTime()) / (1000 * 60 * 60 * 24));
              if (daysPassed > 0) {
                var isLeapYear = (currentYear % 4 === 0 && currentYear % 100 !== 0) || (currentYear % 400 === 0);
                var daysInYear = isLeapYear ? 366 : 365;
                var prediction = Math.round((yearCount / daysPassed) * daysInYear);
                predictionStr = " - 🔮 prévision : " + formatNumber(prediction) + " fuites";
              }
            }

            var percentageStr = "";
            if (yearSurpassInfo[year] && yearSurpassInfo[year].percentage) {
              var color = yearSurpassInfo[year].diff >= 0 ? "#d9534f" : "#5cb85c";
              percentageStr = " <span style='color: " + color + "; font-weight: bold;'>(" + yearSurpassInfo[year].percentage + ")</span>";
            }
        %>
          <div style="margin-bottom: 8px;">
            <a href="#year_heading_<%= year %>" style="font-size: 1.05em; color: #e2e8f0; text-decoration: none;">
              <i class="fa fa-chevron-right me-2" style="font-size: 0.8em; color: #38bdf8;"></i>
              <strong><%= year %></strong> (<%= yearCount %> <%= pluralize(yearCount, 'fuite', 'fuites') %>)<%- percentageStr %> avec <%= totalPwnCountFormatted %> <%= pluralize(totalPwnRaw, 'ligne cumulée', 'lignes cumulées') %><%- avgTimeStr %><%- lateStr %><%- predictionStr %>
            </a>
          </div>
        <% }); %>
      </div>

      <!-- Liste détaillée des fuites -->
      <div class="archive">
        <% Object.keys(archiveData.years).sort(function(a, b){ return b - a; }).forEach(function(year) { %>
          <% 
          var monthsInYear = archiveData.years[year];
          var yearCount = 0;
          var totalPwnRaw = 0;
          var allYearItems = [];
          Object.keys(monthsInYear).forEach(function(m){
            yearCount += monthsInYear[m].length;
            allYearItems = allYearItems.concat(monthsInYear[m]);
            monthsInYear[m].forEach(function(it){ totalPwnRaw += (Number(it.PwnCount) || 0); });
          });
          var totalPwnCountFormatted = formatNumber(totalPwnRaw);
          
          allYearItems.sort(function(a, b){ return new Date(a.BreachDate) - new Date(b.BreachDate); });
          var avgTimeStr = "";
          if (allYearItems.length > 1) {
            var totalDiff = 0;
            for (var i = 1; i < allYearItems.length; i++) {
              totalDiff += new Date(allYearItems[i].BreachDate).getTime() - new Date(allYearItems[i-1].BreachDate).getTime();
            }
            var avgDiffDays = Math.round(totalDiff / (allYearItems.length - 1) / (1000 * 60 * 60 * 24));
            avgTimeStr = " <small style='font-size:0.6em; color:#999;'>&nbsp;(moyenne " + avgDiffDays + " j. entre chaque fuite)</small>";
          }

          var predictionStr = "";
          var currentYear = ARCHIVE_NOW.getFullYear();
          if (parseInt(year) === currentYear) {
            var startOfYear = new Date(currentYear, 0, 1);
            var daysPassed = Math.ceil((ARCHIVE_NOW_TIME - startOfYear.getTime()) / (1000 * 60 * 60 * 24));
            if (daysPassed > 0) {
              var isLeapYear = (currentYear % 4 === 0 && currentYear % 100 !== 0) || (currentYear % 400 === 0);
              var daysInYear = isLeapYear ? 366 : 365;
              var prediction = Math.round((yearCount / daysPassed) * daysInYear);
              predictionStr = " <small style='font-size:0.6em; color:#999;'>&nbsp;- 🔮 prédiction : " + formatNumber(prediction) + " fuites</small>";
            }
          }

          var percentageStr = "";
          if (yearSurpassInfo[year] && yearSurpassInfo[year].percentage) {
            var color = yearSurpassInfo[year].diff >= 0 ? "#d9534f" : "#5cb85c";
            percentageStr = " <small style='font-size:0.6em; color: " + color + ";'>&nbsp;(" + yearSurpassInfo[year].percentage + ")</small>";
          }
          %>
          <h4 id="year_heading_<%= year %>" class="archive-ul" data-toggle="collapse" data-target="#year_<%= year %>"><%= year %> (<%= yearCount %> <%= pluralize(yearCount, 'fuite', 'fuites') %>)<%- percentageStr %> <b class="caret"></b><%- avgTimeStr %><%- predictionStr %></h4>
          <div id="year_<%= year %>" class="collapse in">
            <h1><%= totalPwnCountFormatted %> <%= pluralize(totalPwnRaw, 'ligne cumulée', 'lignes cumulées') %> </h1>
            <% if (yearSurpassInfo[year] && yearSurpassInfo[year].date) { %>
              <p style="margin: 10px 0; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                <strong>📊</strong> Le nombre de fuites de <%= yearSurpassInfo[year].prevYear %> (<%= yearSurpassInfo[year].prevYearCount %> fuites) a été dépassé le 
                <strong><%= new Date(yearSurpassInfo[year].date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong>
                (au bout de <%= yearSurpassInfo[year].days %> jours).
                <% if (yearSurpassInfo[year].latePercentage > 0) { %>
                  <br><span>🔍 <strong><%= yearSurpassInfo[year].latePercentage %>%</strong> de ces fuites ont été découvertes après la fin de l'année <%= year %>.</span>
                <% } %>
              </p>
            <% } else if (yearSurpassInfo[year] && yearSurpassInfo[year].prevYearCount > 0 && yearCount < yearSurpassInfo[year].prevYearCount) { %>
              <p style="margin: 10px 0; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                <strong>📊</strong> <%= year %> compte <%= yearCount %> fuites, soit <strong><%= (yearCount/yearSurpassInfo[year].prevYearCount*100).toFixed(1) %>%</strong> de l'activité de <%= yearSurpassInfo[year].prevYear %> (<%= yearSurpassInfo[year].prevYearCount %> fuites).
                <% if (yearSurpassInfo[year].latePercentage > 0) { %>
                  <br><span>🔍 <strong><%= yearSurpassInfo[year].latePercentage %>%</strong> de ces fuites ont été découvertes après la fin de l'année <%= year %>.</span>
                <% } %>
              </p>
            <% } else if (yearSurpassInfo[year] && yearSurpassInfo[year].latePercentage > 0) { %>
              <p style="margin: 10px 0; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                🔍 <strong><%= yearSurpassInfo[year].latePercentage %>%</strong> des fuites de <%= year %> ont été découvertes après la fin de l'année.
              </p>
            <% } %>
            
            <% Object.keys(archiveData.years[year]).sort(function(a, b){ return b - a; }).forEach(function(month) { %>
              <% var monthCount = archiveData.years[year][month].length; %>
              <h5 class="archive-ul" data-toggle="collapse" data-target="#month_<%= year %>_<%= month %>"><%= archiveData.months[month] %> (<%= monthCount %>) <b class="caret"></b></h5>
              <div id="month_<%= year %>_<%= month %>" class="collapse in">
                <ol>
                  <% archiveData.years[year][month].forEach(function(item) { %>
                    <% 
                      var addedDate = new Date(item.AddedDate || item.BreachDate);
                      var msLeft = (addedDate.getTime() + ARCHIVE_NEW_PERIOD_MS) - ARCHIVE_NOW_TIME;
                      var isRecentlyAdded = msLeft > 0;
                      var dLeft = Math.floor(msLeft / (1000 * 60 * 60 * 24));
                      var hLeft = Math.floor((msLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                      var mLeft = Math.floor((msLeft % (1000 * 60 * 60)) / (1000 * 60));
                    %>
                    <li class="listing-item">
                      <span class="date_class">fuite du <%= new Date(item.BreachDate).toISOString().split('T')[0] %> ajoutée le <%= new Date(item.AddedDate||item.BreachDate).toISOString().split('T')[0] %></span> &raquo;
                      <span class="title">
                        <a href="<%- url_for('/fuites?id=' + item.index) %>" title="<%= item.Title||item.Name %>"><%= item.Title||item.Name %></a>
                        <% if (isRecentlyAdded) { %>
                          <span class="badge badge-success" style="font-size: 0.7em; background-color: #28a745; margin-left: 5px;" title="Encore <%= dLeft %>j <%= hLeft %>h <%= mLeft %>m">
                            NOUVEAU (<%= dLeft %>j <%= hLeft %>h <%= mLeft %>m)
                          </span>
                        <% } %>
                        <% 
                          var desc = (item.Description || '').toLowerCase();
                          var cont = (item.content || '').toLowerCase();
                          var isSiteClosed = item.isBlocked || 
                            desc.includes('site fermé') || desc.includes('n\'existe plus') || desc.includes('n existe plus') || desc.includes('disparu') || desc.includes('arrêté') || desc.includes('cessation') || desc.includes('fermeture') || desc.includes('site closed') || desc.includes('no longer exists') || desc.includes('defunct') || desc.includes('discontinued') || desc.includes('ceased') || desc.includes('shutdown') || desc.includes('shut down') ||
                            cont.includes('site fermé') || cont.includes('n\'existe plus') || cont.includes('n existe plus') || cont.includes('disparu') || cont.includes('arrêté') || cont.includes('cessation') || cont.includes('fermeture') || cont.includes('site closed') || cont.includes('no longer exists') || cont.includes('defunct') || cont.includes('discontinued') || cont.includes('ceased') || cont.includes('shutdown') || cont.includes('shut down');
                        %>
                        <% if (isSiteClosed) { %>
                          <span class="badge badge-secondary ms-2" style="font-size: 0.7em; background-color: #6c757d;">
                            <i class="fa fa-ban"></i> SITE FERMÉ
                          </span>
                        <% } %>
                        <% if (item.isNSFW) { %>
                          <span class="badge badge-danger ms-2" style="font-size: 0.7em; background-color: #dc3545;">
                            <i class="fa fa-exclamation-circle"></i> NSFW
                          </span>
                        <% } %>
                        <% if (item.tags && item.tags.includes('IA')) { %>
                          <span class="badge badge-info ms-2" style="font-size: 0.7em; background-color: #8b5cf6;">
                            <i class="fa fa-robot"></i> IA
                          </span>
                        <% } %>
                        <% if (item.SeverityLevel) { 
                          var severityColors = {
                            'CRITIQUE': 'danger',
                            'ÉLEVÉ': 'warning',
                            'MODÉRÉ': 'info',
                            'FAIBLE': 'secondary'
                          };
                          var severityIcons = {
                            'CRITIQUE': 'fa-exclamation-triangle',
                            'ÉLEVÉ': 'fa-exclamation-circle',
                            'MODÉRÉ': 'fa-info-circle',
                            'FAIBLE': 'fa-check-circle'
                          };
                        %>
                          <span class="badge badge-<%= severityColors[item.SeverityLevel] %> ms-2" style="font-size: 0.7em;">
                            <i class="fa <%= severityIcons[item.SeverityLevel] %>"></i> <%= item.SeverityLevel %>
                          </span>
                        <% } %>
                      </span>
                    </li>
                  <% }); %>
                </ol>
              </div>
            <% }); %>
          </div>
        <% }); %>
      </div>
    </div>

    <% if (theme.widgets.length) { %>
      <%- partial('sidebar') %>
    <% } %>
  </div>
<% } %>
