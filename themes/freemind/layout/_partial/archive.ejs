
<%
  var title = '';
  if (page.archive) {
    if (page.year) title = page.year + (page.month ? '/' + page.month : '');
    else title = __('archive_a');
  }

  // Utiliser les données de breaches.json
  var posts = site.data.breaches ? site.data.breaches.breaches : [];
  var archiveData = {
      years: {},
      months: ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']
  };
     const invalidcategory=["hygiène numérique","sécurité","cybersécurité","cybercriminalité","cyberguerre"]
  // Ajouter l'index à chaque post et trier
  var filteredPosts = posts.filter((item)=>{
          return item && item.Name && !item.Name.includes('cve')
        }).filter((c)=>{
          if(c && c.Name && c.Name.toLowerCase().includes("cve-")){
            return false
          }
          
              return true
        }).map((item, index) => {
    //item.index = index; // Ajouter l'index pour le lien
    return item;
  }).sort((a, b) => new Date(b.BreachDate) - new Date(a.BreachDate))
    

  filteredPosts.forEach(function(item) {
      var date = new Date(item.BreachDate);
      var year = date.getFullYear();
      var month = date.getMonth();
      
      if (!archiveData.years[year]) {
         archiveData.years[year] = {};
      }
      if (!archiveData.years[year][month]) {
         archiveData.years[year][month] = [];
      }
      archiveData.years[year][month].push(item);
   });
%>

<!-- title -->
<div class="page-header <% if (theme.inverse){ %>page-header-inverse<% } %>">
  <h1 class="archive-title title <% if (theme.inverse){ %>title-inverse<% } %>"><%= title %></h1>
  <% if (filteredPosts && filteredPosts.length) { %>
    <div class="archive-year-nav">
      <% 
      // Calculer les dates de dépassement pour toutes les années
      var yearSurpassInfo = {};
      var totalYears = Object.keys(archiveData.years).length;
      var totalBreaches = filteredPosts.length;
      var avgBreachesPerYear = totalBreaches / totalYears;
      
      Object.keys(archiveData.years).sort((a, b) => a - b).forEach(function(year) {
        var yearCount = Object.keys(archiveData.years[year]).reduce(function(total, monthKey) { 
          return total + archiveData.years[year][monthKey].length; 
        }, 0);
        
        var allYearItems = [];
        Object.keys(archiveData.years[year]).forEach(function(monthKey) {
          allYearItems = allYearItems.concat(archiveData.years[year][monthKey]);
        });
        allYearItems.sort((a, b) => new Date(a.BreachDate) - new Date(b.BreachDate));
        
        var prevYear = parseInt(year) - 1;
        var prevYearCount = 0;
        
        if (archiveData.years[prevYear]) {
          prevYearCount = Object.keys(archiveData.years[prevYear]).reduce(function(total, monthKey) {
            return total + archiveData.years[prevYear][monthKey].length;
          }, 0);
          
          if (yearCount >= prevYearCount && prevYearCount > 0) {
            var surpassDate = new Date(allYearItems[prevYearCount - 1].BreachDate);
            var daysSinceStart = Math.ceil((surpassDate - new Date(year, 0, 1)) / (1000 * 60 * 60 * 24));
            yearSurpassInfo[year] = {
              date: surpassDate,
              days: daysSinceStart,
              prevYear: prevYear,
              prevYearCount: prevYearCount,
              type: 'prevYear'
            };
          }
        }
        
        // Calculer le dépassement de la moyenne
        var avgBreachIndex = Math.ceil(avgBreachesPerYear);
        if (yearCount >= avgBreachIndex && allYearItems.length >= avgBreachIndex) {
          var avgSurpassDate = new Date(allYearItems[avgBreachIndex - 1].BreachDate);
          var avgDaysSinceStart = Math.ceil((avgSurpassDate - new Date(year, 0, 1)) / (1000 * 60 * 60 * 24));
          
          if (!yearSurpassInfo[year]) {
            yearSurpassInfo[year] = {};
          }
          yearSurpassInfo[year].avgDate = avgSurpassDate;
          yearSurpassInfo[year].avgDays = avgDaysSinceStart;
          yearSurpassInfo[year].avgCount = avgBreachIndex;
        }
      });
      %>

      <!-- Graphe D3.js -->
      <div id="breach-chart-container" style="margin: 20px 0; padding: 20px; background: #000; border-radius: 8px; border: 1px solid #00ff41; position: relative; overflow: hidden; box-shadow: 0 0 15px rgba(0, 255, 65, 0.2);">
        <h3 style="color: #00ff41; font-family: 'Courier New', Courier, monospace; margin-top: 0; margin-bottom: 20px; font-size: 1.2em; text-transform: uppercase; letter-spacing: 2px;">
          <i class="fa fa-line-chart"></i> Évolution temporelle des fuites
        </h3>
        <div id="breach-chart"></div>
        <div id="chart-tooltip" style="position: absolute; visibility: hidden; background: rgba(0,0,0,0.9); color: #00ff41; padding: 10px; border: 1px solid #00ff41; border-radius: 4px; pointer-events: none; font-family: 'Courier New', Courier, monospace; font-size: 0.9em; z-index: 1000; box-shadow: 0 0 10px rgba(0,255,65,0.3);"></div>
      </div>

      <script src="https://d3js.org/d3.v7.min.js"></script>
      <script>
        (function() {
          const yearsData = <%- JSON.stringify(archiveData.years) %>;
          const surpassInfo = <%- JSON.stringify(yearSurpassInfo) %>;
          const currentYear = new Date().getFullYear();
          
          const allBreaches = [];
          Object.keys(yearsData).forEach(year => {
            Object.keys(yearsData[year]).forEach(month => {
              yearsData[year][month].forEach(breach => {
                allBreaches.push({
                  date: new Date(breach.BreachDate),
                  year: parseInt(year)
                });
              });
            });
          });
          
          allBreaches.sort((a, b) => a.date - b.date);
          
          let cumulative = 0;
          const chartData = allBreaches.map(b => {
            cumulative++;
            return {
              date: b.date,
              value: cumulative,
              year: b.year
            };
          });

          const margin = {top: 20, right: 50, bottom: 40, left: 60};
          const container = d3.select("#breach-chart");
          const width = container.node().getBoundingClientRect().width - margin.left - margin.right;
          const height = 300 - margin.top - margin.bottom;

          const svg = container.append("svg")
              .attr("width", width + margin.left + margin.right)
              .attr("height", height + margin.top + margin.bottom)
            .append("g")
              .attr("transform", `translate(${margin.left},${margin.top})`);

          const x = d3.scaleTime()
            .domain(d3.extent(chartData, d => d.date))
            .range([0, width]);

          const y = d3.scaleLinear()
            .domain([0, d3.max(chartData, d => d.value) * 1.1])
            .nice()
            .range([height, 0]);

          svg.append("g")
            .attr("transform", `translate(0,${height})`)
            .call(d3.axisBottom(x).ticks(width / 80).tickFormat(d3.timeFormat("%Y")))
            .attr("color", "#008f11")
            .selectAll("text")
            .style("font-family", "'Courier New', Courier, monospace");

          svg.append("g")
            .call(d3.axisLeft(y))
            .attr("color", "#008f11")
            .selectAll("text")
            .style("font-family", "'Courier New', Courier, monospace");

          svg.append("path")
            .datum(chartData)
            .attr("fill", "none")
            .attr("stroke", "#00ff41")
            .attr("stroke-width", 2)
            .attr("d", d3.line()
              .x(d => x(d.date))
              .y(d => y(d.value))
              .curve(d3.curveStepAfter)
            );

          // Annotations de dÃ©passement
          Object.keys(surpassInfo).forEach(year => {
            const info = surpassInfo[year];
            if (info.avgDate) {
              const d = new Date(info.avgDate);
              const point = chartData.find(p => p.date.getTime() === d.getTime());
              if (point) {
                svg.append("circle")
                  .attr("cx", x(d))
                  .attr("cy", y(point.value))
                  .attr("r", 4)
                  .attr("fill", "#ff00ff")
                  .attr("stroke", "#fff")
                  .on("mouseover", (event) => {
                    d3.select("#chart-tooltip")
                      .style("visibility", "visible")
                      .html(`<strong>DÃ©passement Moyenne ${year}</strong><br/>Le ${d.toLocaleDateString('fr-FR')}<br/>Total: ${point.value}`)
                      .style("top", (event.pageY - 80) + "px")
                      .style("left", (event.pageX + 10) + "px");
                  })
                  .on("mouseout", () => d3.select("#chart-tooltip").style("visibility", "hidden"));
              }
            }
            if (info.date) {
              const d = new Date(info.date);
              const point = chartData.find(p => p.date.getTime() === d.getTime());
              if (point) {
                svg.append("circle")
                  .attr("cx", x(d))
                  .attr("cy", y(point.value))
                  .attr("r", 4)
                  .attr("fill", "#ffff00")
                  .attr("stroke", "#fff")
                  .on("mouseover", (event) => {
                    d3.select("#chart-tooltip")
                      .style("visibility", "visible")
                      .html(`<strong>DÃ©passement ${info.prevYear}</strong><br/>Le ${d.toLocaleDateString('fr-FR')}<br/>Total: ${point.value}`)
                      .style("top", (event.pageY - 80) + "px")
                      .style("left", (event.pageX + 10) + "px");
                  })
                  .on("mouseout", () => d3.select("#chart-tooltip").style("visibility", "hidden"));
              }
            }
          });

          const focus = svg.append("g").style("display", "none");
          focus.append("circle").attr("r", 5).attr("fill", "#00ff41").attr("stroke", "#fff");
          
          svg.append("rect")
            .attr("width", width)
            .attr("height", height)
            .style("fill", "none")
            .style("pointer-events", "all")
            .on("mouseover", () => focus.style("display", null))
            .on("mouseout", () => {
              focus.style("display", "none");
              d3.select("#chart-tooltip").style("visibility", "hidden");
            })
            .on("mousemove", (event) => {
              const x0 = x.invert(d3.pointer(event)[0]);
              const i = d3.bisector(d => d.date).left(chartData, x0, 1);
              const d = chartData[i - 1];
              if (d) {
                focus.attr("transform", `translate(${x(d.date)},${y(d.value)})`);
                d3.select("#chart-tooltip")
                  .style("visibility", "visible")
                  .html(`Le ${d.date.toLocaleDateString('fr-FR')}<br/><strong>${d.value} fuites cumulÃ©es</strong>`)
                  .style("top", (event.pageY - 80) + "px")
                  .style("left", (event.pageX + 10) + "px");
              }
            });
        })();
      </script>
      
      <% Object.keys(archiveData.years).sort((a, b) => a - b).forEach(function(year) { %>
        <% 
        var yearCount = Object.keys(archiveData.years[year]).reduce(function(total, monthKey) { return total + archiveData.years[year][monthKey].length; }, 0);
        var totalPwnCount =  new Intl.NumberFormat(["EN-US"]).format(Object.keys(archiveData.years[year]).reduce(    (total, monthKey) => total + archiveData.years[year][monthKey].reduce(        (monthTotal, item) => monthTotal + (item.PwnCount || 0), 0 ), 0)); 
        
        var allYearItems = [];
        Object.keys(archiveData.years[year]).forEach(function(monthKey) {
          allYearItems = allYearItems.concat(archiveData.years[year][monthKey]);
        });
        allYearItems.sort((a, b) => new Date(a.BreachDate) - new Date(b.BreachDate));
        var avgTimeStr = "";
        if (allYearItems.length > 1) {
          var totalDiff = 0;
          for (var i = 1; i < allYearItems.length; i++) {
            totalDiff += new Date(allYearItems[i].BreachDate) - new Date(allYearItems[i-1].BreachDate);
          }
          var avgDiffDays = Math.round(totalDiff / (allYearItems.length - 1) / (1000 * 60 * 60 * 24));
          avgTimeStr = " - en moyenne " + avgDiffDays + " j. entre 2 fuites";
        }
        %>

        <a href="#year_heading_<%= year %>"><%= year %> (<%= yearCount %>) avec <%= totalPwnCount %> ligne cumulée de données fuitée<%= avgTimeStr %></a>
        <% if (yearSurpassInfo[year]) { %>
          <div style="margin-left: 20px; margin-top: 5px; margin-bottom: 5px; font-size: 0.9em; color: #666; font-style: italic;">
            <% if (yearSurpassInfo[year].date) { %>
              📊 Dépassement de <%= yearSurpassInfo[year].prevYear %> (<%= yearSurpassInfo[year].prevYearCount %> fuites) le 
              <strong><%= yearSurpassInfo[year].date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' }) %></strong>
              (au bout de <%= yearSurpassInfo[year].days %> jours)
            <% } %>
          </div>
          <% if (yearSurpassInfo[year].avgDate) { %>
            <div style="margin-left: 20px; margin-top: 0; margin-bottom: 10px; font-size: 0.9em; color: #888; font-style: italic;">
              📈 Dépassement de la moyenne annuelle (<%= Math.round(avgBreachesPerYear) %> fuites) le 
              <strong><%= yearSurpassInfo[year].avgDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' }) %></strong>
              (au bout de <%= yearSurpassInfo[year].avgDays %> jours)
            </div>
          <% } %>
        <% } else { %>
          </br>
        <% } %>
      <% }); %>
    </div>
  <% } %>
</div>

<% if (!filteredPosts || filteredPosts.length === 0) { %>
  <div class="alert alert-info" role="alert">
    Aucune fuite de données trouvée.
  </div>
<% } else { %>
  <div class="row page">
    <div class="<% if (theme.widgets.length) { %>col-md-9<% } else { %>col-md-12<% } %>">
      <div class="archive">
        <% Object.keys(archiveData.years).sort((a, b) => b - a).forEach(function(year) { %>
          <% 
          var yearCount = Object.keys(archiveData.years[year]).reduce(function(total, monthKey) { return total + archiveData.years[year][monthKey].length; }, 0);
          var totalPwnCount =  new Intl.NumberFormat(["EN-US"]).format(Object.keys(archiveData.years[year]).reduce(    (total, monthKey) => total + archiveData.years[year][monthKey].reduce(        (monthTotal, item) => monthTotal + (item.PwnCount || 0), 0 ), 0)); 
          
          var allYearItems = [];
          Object.keys(archiveData.years[year]).forEach(function(monthKey) {
            allYearItems = allYearItems.concat(archiveData.years[year][monthKey]);
          });
          allYearItems.sort((a, b) => new Date(a.BreachDate) - new Date(b.BreachDate));
          var avgTimeStr = "";
          if (allYearItems.length > 1) {
            var totalDiff = 0;
            for (var i = 1; i < allYearItems.length; i++) {
              totalDiff += new Date(allYearItems[i].BreachDate) - new Date(allYearItems[i-1].BreachDate);
            }
            var avgDiffDays = Math.round(totalDiff / (allYearItems.length - 1) / (1000 * 60 * 60 * 24));
            avgTimeStr = " <small style='font-size:0.6em; color:#999;'>&nbsp;(moyenne " + avgDiffDays + " j. entre chaque fuite)</small>";
          }
          %>
          <h4 id="year_heading_<%= year %>" class="archive-ul" data-toggle="collapse" data-target="#year_<%= year %>"><%= year %> (<%= yearCount %>) <b class="caret"></b><%- avgTimeStr %></h4>
          <div id="year_<%= year %>" class="collapse in">
            <h1><%= totalPwnCount %> ligne cumulée </h1>
            <% 
            // Calculer quand cette année a dépassé l'année précédente
            var prevYear = parseInt(year) - 1;
            var prevYearCount = 0;
            var yearSurpassDate = null;
            
            if (archiveData.years[prevYear]) {
              prevYearCount = Object.keys(archiveData.years[prevYear]).reduce(function(total, monthKey) {
                return total + archiveData.years[prevYear][monthKey].length;
              }, 0);
              
              if (yearCount >= prevYearCount && prevYearCount > 0) {
                var sortedYearBreaches = allYearItems.slice();
                sortedYearBreaches.sort((a, b) => new Date(a.BreachDate) - new Date(b.BreachDate));
                yearSurpassDate = new Date(sortedYearBreaches[prevYearCount - 1].BreachDate);
              }
            }
            %>
            <% if (yearSurpassDate) { %>
              <p style="margin: 10px 0; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                <strong>📊</strong> Le nombre de fuites de <%= prevYear %> (<%= prevYearCount %> fuites) a été dépassé le 
                <strong><%= yearSurpassDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong>
                (au bout de <%= Math.ceil((yearSurpassDate - new Date(year, 0, 1)) / (1000 * 60 * 60 * 24)) %> jours).
              </p>
            <% } else if (prevYearCount > 0 && yearCount < prevYearCount) { %>
              <p style="margin: 10px 0; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                <strong>📊</strong> <%= year %> compte <%= yearCount %> fuites, contre <%= prevYearCount %> fuites en <%= prevYear %>.
              </p>
            <% } %>
            
            <% Object.keys(archiveData.years[year]).sort((a, b) => b - a).forEach(function(month) { %>
              <% var monthCount = archiveData.years[year][month].length; %>
              <h5 class="archive-ul" data-toggle="collapse" data-target="#month_<%= year %>_<%= month %>"><%= archiveData.months[month] %> (<%= monthCount %>) <b class="caret"></b></h5>
              <div id="month_<%= year %>_<%= month %>" class="collapse in">
                <ol>
                  <% archiveData.years[year][month].forEach(function(item) { %>
                    <li class="listing-item">
                      <span class="date_class"><%= new Date(item.BreachDate).toISOString().split('T')[0] %></span> &raquo;
                      <span class="title">
                        <a href="<%- url_for('/fuites?id=' + item.index) %>" title="<%= item.Title||item.Name %>"><%= item.Title||item.Name %></a>
                        <% if (item.SeverityLevel) { 
                          var severityColors = {
                            'CRITIQUE': 'danger',
                            'ÉLEVÉ': 'warning',
                            'MODÉRÉ': 'info',
                            'FAIBLE': 'secondary'
                          };
                          var severityIcons = {
                            'CRITIQUE': 'fa-exclamation-triangle',
                            'ÉLEVÉ': 'fa-exclamation-circle',
                            'MODÉRÉ': 'fa-info-circle',
                            'FAIBLE': 'fa-check-circle'
                          };
                        %>
                          <span class="badge badge-<%= severityColors[item.SeverityLevel] %> ms-2" style="font-size: 0.7em;">
                            <i class="fa <%= severityIcons[item.SeverityLevel] %>"></i> <%= item.SeverityLevel %>
                          </span>
                        <% } %>
                      </span>
                    </li>
                  <% }); %>
                </ol>
              </div>
            <% }); %>
          </div>
        <% }); %>
      </div>
    </div>
  </div>
<% } %>
