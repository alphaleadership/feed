<div style="background: #1e293b; padding: 20px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #334155;">
  <h1 style="color: #00ff41; margin-top: 0;"><i class="fa fa-share-alt me-2"></i> Réseau des Fuites de Données</h1>
  <p style="color: #94a3b8; font-size: 1.1em; margin-bottom: 10px;">
    Explorez visuellement les liens entre les différentes fuites, les types de données compromises, les catégories d'entreprises et les groupes de pirates.
  </p>
  
  <div style="display: flex; gap: 15px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; background: rgba(15, 23, 42, 0.5); padding: 15px; border-radius: 6px;">
    <label for="category-filter" style="color: #00ff41; margin-bottom: 0; font-weight: bold;"><i class="fa fa-filter me-2"></i>Filtrer par catégorie :</label>
    <select id="category-filter" style="background: #0f172a; color: #fff; border: 1px solid #00ff41; padding: 5px 10px; border-radius: 4px; min-width: 200px;">
      <option value="all">Toutes les catégories</option>
    </select>
    <div id="node-count" style="color: #94a3b8; font-size: 0.9em; margin-left: auto;">Chargement...</div>
  </div>

  <div id="graph-legend" style="display: flex; gap: 15px; flex-wrap: wrap;">
     <span class="badge legend-item" data-group="1" style="background-color: #ef4444; color: white; padding: 8px 12px; font-size: 0.9em; cursor: pointer; transition: opacity 0.2s;"><i class="fa fa-database me-1"></i> Fuite de données</span>
     <span class="badge legend-item" data-group="2" style="background-color: #3b82f6; color: white; padding: 8px 12px; font-size: 0.9em; cursor: pointer; transition: opacity 0.2s;"><i class="fa fa-tags me-1"></i> Type de donnée</span>
     <span class="badge legend-item" data-group="3" style="background-color: #10b981; color: white; padding: 8px 12px; font-size: 0.9em; cursor: pointer; transition: opacity 0.2s;"><i class="fa fa-folder-open me-1"></i> Secteur / Catégorie</span>
     <span class="badge legend-item" data-group="4" style="background-color: #f59e0b; color: white; padding: 8px 12px; font-size: 0.9em; cursor: pointer; transition: opacity 0.2s;"><i class="fa fa-user-secret me-1"></i> Groupe Pirate</span>
  </div>
</div>

<div id="graph-container" style="width: 100%; height: 75vh; border: 2px solid #00ff41; border-radius: 8px; box-shadow: 0 0 15px rgba(0, 255, 65, 0.2); overflow: hidden; background-color: #0f172a;"></div>

<style>
  .graph-tooltip {
    background: rgba(15, 23, 42, 0.95);
    color: #fff;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 14px;
    border: 1px solid #00ff41;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
    pointer-events: none;
    max-width: 300px;
  }
  .graph-tooltip strong {
    color: #00ff41;
    font-size: 1.2em;
    display: block;
    margin-bottom: 5px;
  }
  .graph-tooltip small {
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: bold;
  }
  .legend-item.inactive {
    opacity: 0.3;
    filter: grayscale(0.5);
  }
</style>

<script src="//unpkg.com/force-graph"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const elem = document.getElementById('graph-container');
    const filterSelect = document.getElementById('category-filter');
    const countDisplay = document.getElementById('node-count');
    const legendItems = document.querySelectorAll('.legend-item');
    if (!elem) return;

    let fullData = { nodes: [], links: [] };
    let Graph = null;
    let hiddenGroups = new Set();
    
    // Variables pour l'optimisation au survol
    let hoveredNode = null;
    let hoveredLink = null;

    function initGraph(data) {
      try {
        Graph = ForceGraph()(elem);

        // Optimisation 1 : Pré-calculer les couleurs des nœuds pour éviter de réévaluer à chaque frame
        data.nodes.forEach(node => {
          if (!node.color) {
            if (node.group === 1) node.color = '#ef4444';
            else if (node.group === 2) node.color = '#3b82f6';
            else if (node.group === 3) node.color = '#10b981';
            else if (node.group === 4) node.color = '#f59e0b';
            else node.color = '#64748b';
          }
        });

        Graph.graphData(data)
          .nodeLabel(node => `<div class="graph-tooltip"><strong>${node.name || 'Inconnu'}</strong><br><small>${node.type || 'Non défini'}</small></div>`)
          .nodeColor(node => node.color)
          .nodeVal(node => (node.val || 1) * 2)
          .linkColor(link => link === hoveredLink ? '#00ff41' : 'rgba(0, 255, 65, 0.15)')
          .linkWidth(link => link === hoveredLink ? 2 : 0.5)
          // Optimisation 2 : Désactiver les particules animées par défaut (très gourmandes)
          // On ne les active que sur le lien survolé
          .linkDirectionalParticles(link => link === hoveredLink ? 4 : 0)
          .linkDirectionalParticleSpeed(0.01)
          .linkDirectionalParticleWidth(2)
          .linkDirectionalParticleColor(() => '#00ff41');

        // Optimisation 3 : Alléger les forces pour une stabilisation plus rapide
        Graph.d3Force('charge').strength(-300).distanceMax(300);
        Graph.d3Force('link').distance(80);

        // Optimisation 4 : Rendu Custom ultra-rapide
        Graph.nodeCanvasObject((node, ctx, globalScale) => {
          const isHovered = node === hoveredNode;
          
          // Cercle de fond
          ctx.beginPath();
          ctx.arc(node.x, node.y, (node.val || 1) * (isHovered ? 4 : 3), 0, 2 * Math.PI, false);
          ctx.fillStyle = node.color;
          ctx.fill();

          // N'afficher le texte que si on est zoomé, ou si c'est un nœud majeur, ou survolé
          const showLabel = isHovered || globalScale > 2 || (globalScale > 0.8 && (node.group === 1 || node.group === 4));
          
          if (showLabel) {
            const label = node.name;
            const fontSize = (node.group === 1 ? 14 : 10) / globalScale;
            ctx.font = `${fontSize}px Sans-Serif`;
            
            // Optimisation MAJEURE : Mettre en cache la taille du texte pour éviter measureText (très lent)
            if (!node.__textWidth) {
              node.__textWidth = ctx.measureText(label).width;
            }
            
            const bckgDimensions = [node.__textWidth, fontSize].map(n => n + fontSize * 0.3);

            ctx.fillStyle = 'rgba(15, 23, 42, 0.9)';
            ctx.fillRect(node.x - bckgDimensions[0] / 2, node.y - fontSize * 2.2, bckgDimensions[0], bckgDimensions[1]);
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillStyle = '#fff';
            ctx.fillText(label, node.x, node.y - fontSize * 1.8);
          }
        });

        Graph.onNodeClick(node => {
          if (node.url) {
            window.location.href = node.url;
          } else {
            Graph.centerAt(node.x, node.y, 1000);
            Graph.zoom(3, 1000);
          }
        })
        .onNodeHover(node => {
           elem.style.cursor = node && node.url ? 'pointer' : node ? 'crosshair' : 'grab';
           hoveredNode = node;
        })
        .onLinkHover(link => {
           hoveredLink = link;
        })
        // Optimisation 5 : Limiter la simulation physique et figer le graphe une fois stable (épargne le CPU/Batterie)
        .cooldownTicks(150)
        .onEngineStop(() => {
           Graph.zoomToFit(400, 20);
        });

      } catch (err) {
        console.error("Erreur d'initialisation du graphe:", err);
      }
    }

    function applyFilters() {
      const category = filterSelect.value;
      
      let filteredNodes = fullData.nodes.filter(node => !hiddenGroups.has(node.group));
      
      if (category !== 'all') {
        filteredNodes = filteredNodes.filter(node => 
          node.cats && node.cats.includes(category)
        );
      }
      
      const nodeIds = new Set(filteredNodes.map(n => n.id));
      const filteredLinks = fullData.links.filter(link => 
        nodeIds.has(link.source.id || link.source) && nodeIds.has(link.target.id || link.target)
      );

      // On réapplique la logique de couleur aux nouveaux noeuds au cas où
      filteredNodes.forEach(node => {
        if (!node.color) {
          if (node.group === 1) node.color = '#ef4444';
          else if (node.group === 2) node.color = '#3b82f6';
          else if (node.group === 3) node.color = '#10b981';
          else if (node.group === 4) node.color = '#f59e0b';
          else node.color = '#64748b';
        }
      });

      Graph.graphData({ nodes: filteredNodes, links: filteredLinks });
      countDisplay.textContent = `${filteredNodes.length} nœuds affichés`;
    }

    legendItems.forEach(item => {
      item.addEventListener('click', () => {
        const group = parseInt(item.getAttribute('data-group'));
        if (hiddenGroups.has(group)) {
          hiddenGroups.delete(group);
          item.classList.remove('inactive');
        } else {
          hiddenGroups.add(group);
          item.classList.add('inactive');
        }
        applyFilters();
      });
    });

    filterSelect.addEventListener('change', applyFilters);

    fetch('/graph/data.json')
      .then(res => res.json())
      .then(data => {
        fullData = data;
        const categories = new Set();
        data.nodes.forEach(node => {
          if (node.group === 3) categories.add(node.name);
        });

        Array.from(categories).sort().forEach(cat => {
          const opt = document.createElement('option');
          opt.value = cat;
          opt.textContent = cat;
          filterSelect.appendChild(opt);
        });

        initGraph(data);
        countDisplay.textContent = `${data.nodes.length} nœuds affichés`;
      })
      .catch(err => {
        console.error("Erreur de chargement du graphe:", err);
        elem.innerHTML = '<div style="color: #ef4444; padding: 20px;">Erreur de chargement des données.</div>';
      });
  });
</script>